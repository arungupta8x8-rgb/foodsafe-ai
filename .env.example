# Gemini API Configuration (Default Provider)
# Get your API key from: https://makersuite.google.com/app/apikey
VITE_GEMINI_API_KEY=your_gemini_api_key_here

# Grok API Configuration (Optional - for advanced features)
# Get your API key from: https://console.x.ai
VITE_GROK_API_KEY=your_grok_api_key_here

# Note: Gemini is used as default provider for faster responses
# Grok can be selected in AI Provider Selector if API key is provided
